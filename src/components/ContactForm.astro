---
// Komponent renderuje się statycznie, cała logika w <script>
---

<section id="kontakt" class="bg-gray-50 py-16 px-4">
  <div class="max-w-xl mx-auto">
    <h2 class="text-3xl font-bold text-gray-900 mb-2">Skontaktuj się z nami</h2>
    <p class="text-gray-500 mb-8">Odpiszemy najszybciej jak to możliwe.</p>

    <form id="contact-form" class="mb-8" novalidate>
      <div class="mb-5">
        <label
          for="from_name"
          class="block text-sm font-medium text-gray-700 mb-1"
        >
          Imię
        </label>
        <input
          id="from_name"
          name="from_name"
          type="text"
          required
          placeholder="Jan Kowalski"
          class="w-full border border-gray-300 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-red-500 focus:border-transparent transition"
        />
      </div>

      <div class="mb-5">
        <label
          for="from_email"
          class="block text-sm font-medium text-gray-700 mb-1"
        >
          Email
        </label>
        <input
          id="from_email"
          name="from_email"
          type="email"
          required
          placeholder="jan@example.com"
          class="w-full border border-gray-300 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-red-500 focus:border-transparent transition"
        />
      </div>

      <div class="mb-6">
        <label
          for="message"
          class="block text-sm font-medium text-gray-700 mb-1"
        >
          Wiadomość
        </label>
        <textarea
          id="message"
          name="message"
          required
          rows="5"
          placeholder="Opisz usterkę swojego telefonu..."
          class="w-full border border-gray-300 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-red-500 focus:border-transparent transition resize-none"
        ></textarea>
      </div>

      <!-- Status wysyłki -->
      <p id="form-status" class="text-sm mb-4 hidden"></p>

      <button
        type="submit"
        id="submit-btn"
        class="w-full bg-red-600 hover:bg-red-700 text-white font-semibold py-3 rounded-lg transition-colors disabled:opacity-50 disabled:cursor-not-allowed cursor-pointer"
      >
        Wyślij wiadomość
      </button>
    </form>

    <div class="flex flex-col justify-center items-center">
      <h3 class="text-2xl font-bold text-gray-900 mb-1.5">Wolisz zadzwonić?</h3>
      <p class="text-gray-500 mb-2.5">Nie ma problemu!</p>
      <a
        href="tel:607858300"
        class="text-2xl text-red-600 lato-bold flex items-center gap-x-1.5"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          fill="none"
          viewBox="0 0 24 24"
          stroke-width="1.5"
          stroke="currentColor"
          class="size-6"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z"
          ></path>
        </svg> 607 858 300
      </a>
    </div>
  </div>
</section>

<script>
  import emailjs from "@emailjs/browser";

  const SERVICE_ID = import.meta.env.PUBLIC_EMAILJS_SERVICE_ID;
  const TEMPLATE_ID = import.meta.env.PUBLIC_EMAILJS_TEMPLATE_ID;
  const PUBLIC_KEY = import.meta.env.PUBLIC_EMAILJS_PUBLIC_KEY;

  emailjs.init({ publicKey: PUBLIC_KEY });

  const form = document.getElementById("contact-form") as HTMLFormElement;
  const statusEl = document.getElementById(
    "form-status",
  ) as HTMLParagraphElement;
  const submitBtn = document.getElementById("submit-btn") as HTMLButtonElement;

  form.addEventListener("submit", async (e) => {
    e.preventDefault();

    // Walidacja
    if (!form.checkValidity()) {
      form.reportValidity();
      return;
    }

    // Stan ładowania
    submitBtn.disabled = true;
    submitBtn.textContent = "Wysyłanie...";
    statusEl.className = "text-sm mb-4 hidden";

    try {
      await emailjs.sendForm(SERVICE_ID, TEMPLATE_ID, form);

      statusEl.textContent = "Wiadomość wysłana! Odezwiemy się wkrótce.";
      statusEl.className = "text-sm mb-4 text-green-600";
      form.reset();
    } catch (err) {
      statusEl.textContent =
        "Coś poszło nie tak. Spróbuj ponownie lub zadzwoń do nas.";
      statusEl.className = "text-sm mb-4 text-red-600";
      console.error("EmailJS error:", err);
    } finally {
      submitBtn.disabled = false;
      submitBtn.textContent = "Wyślij wiadomość";
    }
  });
</script>
