---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { hygraphQuery, toSlug } from "../lib/hygraph";
import { GET_BRANDS, GET_BRAND_WITH_MODELS } from "../lib/queries";
import type { Brand } from "../lib/queries";

export async function getStaticPaths() {
  const data = await hygraphQuery<{ brands: Pick<Brand, "name">[] }>(GET_BRANDS);

  return data.brands.map((brand) => ({
    params: {
      brand: toSlug(brand.name),
    },
    props: {
      brandName: brand.name,
    },
  }));
}

const { brandName } = Astro.props;
const { brand: brandSlug } = Astro.params;

const data = await hygraphQuery<{ brand: Brand }>(GET_BRAND_WITH_MODELS, {
  name: brandName,
});

const brandData = data.brand;
---

<BaseLayout title={`Naprawa ${brandData.name} – GSMdoctor`}>
  <Header />

  <main class="container mx-auto py-12 px-4 max-w-4xl">

    <nav class="text-sm text-gray-500 mb-8" aria-label="Breadcrumb">
      <a href="/" class="hover:text-red-600 transition-colors">Strona główna</a>
      <span class="mx-2">/</span>
      <span class="text-gray-900 font-medium">{brandData.name}</span>
    </nav>

    <h1 class="text-3xl font-bold mb-2">Smartfony {brandData.name}</h1>
    <p class="text-gray-500 mb-10">
      Wybierz model swojego telefonu, aby zobaczyć dostępne naprawy i ceny.
    </p>

    {brandData.models.length === 0 ? (
      <p class="text-gray-400 italic">Brak modeli w bazie.</p>
    ) : (
      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-4">
        {brandData.models.map((model) => (
          <a
            href={`/${brandSlug}/${model.slug}`}
            class="p-4 border border-gray-200 rounded-xl hover:border-red-500 hover:shadow-md transition-all text-center font-medium text-gray-800 hover:text-red-600"
          >
            {model.name}
          </a>
        ))}
      </div>
    )}

  </main>

  <Footer />
</BaseLayout>