---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { hygraphQuery, toSlug } from "../lib/hygraph";
import { getAllModelsWithRepairs } from "../lib/queries";
import type { PhoneModel } from "../lib/queries";

interface BrandPageData {
  name: string;
  models: { name: string; slug: string }[];
}

export async function getStaticPaths() {
  // Pobieramy WSZYSTKIE modele (ze pełną paginacją) i grupujemy po marce
  // w kodzie, zamiast polegać na zagnieżdżonej relacji brand.models w
  // Hygraph — ta relacja ma swój własny limit per-request (np. 100),
  // niezależny od limitu na zapytaniu top-level "models", więc dla marek
  // z dużą liczbą modeli (np. Samsung) ucinałaby listę w ten sam sposób,
  // który wcześniej powodował 404.
  const allModels = await getAllModelsWithRepairs(hygraphQuery);

  const brandMap = new Map<string, BrandPageData>();

  for (const model of allModels) {
    const brandName = model.brand.name;
    if (!brandMap.has(brandName)) {
      brandMap.set(brandName, { name: brandName, models: [] });
    }
    brandMap.get(brandName)!.models.push({
      name: model.name,
      slug: model.slug,
    });
  }

  return Array.from(brandMap.values()).map((brand) => ({
    params: {
      brand: toSlug(brand.name),
    },
    props: {
      brandData: brand,
    },
  }));
}

const { brandData } = Astro.props as { brandData: BrandPageData };
const { brand: brandSlug } = Astro.params;
---

<BaseLayout title={`Naprawa ${brandData.name} – GSMdoctor`}>
  <Header />
  <main class="container mx-auto py-12 px-4 max-w-4xl">
    <nav class="text-sm text-gray-500 mb-8" aria-label="Breadcrumb">
      <a href="/" class="hover:text-red-600 transition-colors">Strona główna</a>
      <span class="mx-2">/</span>
      <span class="text-gray-900 font-medium">{brandData.name}</span>
    </nav>

    <h1 class="text-3xl font-bold mb-2">Smartfony {brandData.name}</h1>
    <p class="text-gray-500 mb-10">
      Wybierz model swojego telefonu, aby zobaczyć dostępne naprawy i ceny.
    </p>

    {brandData.models.length === 0 ? (
      <p class="text-gray-400 italic">Brak modeli w bazie.</p>
    ) : (
      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-4">
        {brandData.models.map((model) => (
          <a
            href={`/${brandSlug}/${model.slug}`}
            class="p-4 border border-gray-200 rounded-xl bg-white hover:border-red-500 hover:shadow-md transition-all text-center font-medium text-gray-800 hover:text-red-600"
          >
            {model.name}
          </a>
        ))}
      </div>
    )}
  </main>
  <Footer />
</BaseLayout>