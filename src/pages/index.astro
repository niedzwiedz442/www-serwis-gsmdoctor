---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import BrandTile from "../components/BrandTile.astro";
import Footer from "../components/Footer.astro";
---

<BaseLayout>
  <Header />
  <div class="hero p-10">
    <div class="container mx-auto text-center py-16">
      <h1 class="text-4xl text-white font-bold mb-6 text-shadow-lg">
        Profesjonalna naprawa telefonów
      </h1>
      <a
        href="#"
        class="bg-red-600 hover:bg-red-800 lato-bold text-white px-6 py-3 rounded-lg transition-colors"
      >
        Umów naprawę
      </a>
    </div>
  </div>
  <main class="flex flex-col items-center py-12">
    <div class="brands-grid grid grid-cols-1 sm:grid-cols-2 gap-6">
      <BrandTile brand="Apple" />
      <BrandTile brand="Samsung" />
    </div>
  </main>
  <Footer />
</BaseLayout>

<style>
  .hero {
    background:
      linear-gradient(rgba(0, 0, 0, 0.5), rgba(0, 0, 0, 0.5)),
      url("/images/hero-bg.jpg") no-repeat center center;
    background-size: cover;
  }
</style>
