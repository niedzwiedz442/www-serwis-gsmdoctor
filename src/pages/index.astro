---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import BrandTile from "../components/BrandTile.astro";
import ContactForm from "../components/ContactForm.astro";
import Footer from "../components/Footer.astro";
import { hygraphQuery, toSlug } from "../lib/hygraph";
import { GET_BRANDS } from "../lib/queries";
import type { Brand } from "../lib/queries";

const data = await hygraphQuery<{ brands: Pick<Brand, "name">[] }>(GET_BRANDS);
const brands = data.brands;
---

<BaseLayout title="GSMdoctor – Profesjonalna naprawa telefonów">
  <Header />

  <div class="hero p-10">
    <div class="container mx-auto text-center py-16">
      <h1 class="text-4xl text-white font-bold mb-6 text-shadow-lg">
        Profesjonalna naprawa telefonów
      </h1>
      <a href="/#kontakt" class="bg-red-600 hover:bg-red-800 text-white lato-bold px-6 py-3 rounded-lg transition-colors">
        Umów naprawę
      </a>
    </div>
  </div>

  <main id="marki" class="flex flex-col items-center py-12">
    <h2 class="text-2xl font-bold mb-8 text-gray-800">Wybierz markę telefonu</h2>
    <div class="brands-grid grid grid-cols-1 sm:grid-cols-2 gap-6">
      {brands.map((brand) => (
        <BrandTile brand={brand.name} slug={toSlug(brand.name)} />
      ))}
    </div>
  </main>

  <ContactForm />

  <Footer />
</BaseLayout>

<style>
  .hero {
    background:
      linear-gradient(rgba(0, 0, 0, 0.5), rgba(0, 0, 0, 0.5)),
      url("/images/hero-bg.jpg") no-repeat center center;
    background-size: cover;
  }
</style>